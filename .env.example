# PostgreSQL connection string (Railway managed PostgreSQL in production)
# Local example: postgresql://postgres:postgres@127.0.0.1:5432/hammer?schema=public
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/hammer?schema=public"

# 32+ chars required for signed auth sessions
AUTH_SESSION_SECRET="replace_with_a_unique_random_secret_min_32_chars"

# Session lifetime in hours (integer >= 1)
AUTH_SESSION_TTL_HOURS="12"

# Optional runtime mode used by docker/entrypoint.sh (development|staging|production)
APP_ENV="development"

# E2E runtime defaults (Playwright)
E2E_BASE_URL="http://127.0.0.1:3000"
E2E_ADMIN_STORAGE_STATE="tests/e2e/.auth/admin.json"
E2E_CASHIER_STORAGE_STATE="tests/e2e/.auth/cashier.json"
E2E_ADMIN_USERNAME="supervisor.mga"
E2E_ADMIN_PASSWORD="ChangeMeNow!123"
E2E_CASHIER_USERNAME="caja.mga"
E2E_CASHIER_PASSWORD="ChangeMeNow!123"
