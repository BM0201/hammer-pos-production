# ===================================================================
# H.A.M.M.E.R. POS - Entorno ejemplo (Railway + PostgreSQL)
# ===================================================================
# Nunca uses estos valores tal cual en producción.

# -------------------------------------------------------------------
# Variables CRÍTICAS (obligatorias)
# -------------------------------------------------------------------

# Railway: asigna esta variable desde PostgreSQL plugin
# Ejemplo local: postgresql://postgres:postgres@127.0.0.1:5432/hammer?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Mínimo 32 caracteres aleatorios únicos.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET="REPLACE_WITH_A_RANDOM_64_CHAR_HEX_SECRET"

# Duración de sesión en horas (entero >= 1)
AUTH_SESSION_TTL_HOURS="12"

# -------------------------------------------------------------------
# Runtime
# -------------------------------------------------------------------
NODE_ENV="production"
APP_ENV="production"
PORT="3000"

# Validación opcional de entorno
# ENV_VALIDATION_MODE=auto|warn|strict
# SKIP_ENV_VALIDATION=true|false

# -------------------------------------------------------------------
# E2E / QA (opcionales para producción)
# -------------------------------------------------------------------
# En Railway puedes omitirlas si no ejecutas e2e dentro del servicio.
E2E_BASE_URL="https://your-app.up.railway.app"
E2E_ADMIN_STORAGE_STATE="tests/e2e/.auth/admin.json"
E2E_CASHIER_STORAGE_STATE="tests/e2e/.auth/cashier.json"
E2E_ADMIN_USERNAME="supervisor.mga"
E2E_ADMIN_PASSWORD="ChangeMeNow!123"
E2E_CASHIER_USERNAME="caja.mga"
E2E_CASHIER_PASSWORD="ChangeMeNow!123"
