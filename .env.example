# ===================================================================
# H.A.M.M.E.R. POS — Variables de Entorno para DESARROLLO / DEMO
# ===================================================================
#
# ⚠️  Este archivo es SOLO para desarrollo local y demos.
#     NO usar estos valores en producción.
#
# Para producción, usar:  .env.production.example
# Para desarrollo local:  .env.local.example  (preferido)
#
# Configuración rápida:
#   cp .env.example .env
#   O mejor:  npm run local:prepare-env
#
# ===================================================================


# -------------------------------------------------------------------
# 🏷️  Entorno
# -------------------------------------------------------------------
# Para producción usar APP_ENV="production" y NODE_ENV="production"
NODE_ENV="development"
APP_ENV="demo"


# -------------------------------------------------------------------
# 🐘 Base de datos — PostgreSQL
# -------------------------------------------------------------------
# URL PostgreSQL válida (postgresql:// o postgres://)
# Para desarrollo local rápido con Docker:
#   docker run -d --name hammer-pg \
#     -e POSTGRES_USER=hammer -e POSTGRES_PASSWORD=hammer \
#     -e POSTGRES_DB=hammer_pos_dev -p 5432:5432 postgres:16-alpine
DATABASE_URL="postgresql://hammer:hammer@localhost:5432/hammer_pos_dev"


# -------------------------------------------------------------------
# 🔐 Seguridad de sesión
# -------------------------------------------------------------------
# En desarrollo se genera automáticamente con: npm run local:prepare-env
# En producción: generar con  openssl rand -hex 32
AUTH_SESSION_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"

# Duración de sesión en horas (24h cómodo para desarrollo)
AUTH_SESSION_TTL_HOURS="24"


# -------------------------------------------------------------------
# ⚙️  Configuración de la aplicación
# -------------------------------------------------------------------
PORT="3000"

# Ejecutar migraciones automáticamente al iniciar
RUN_MIGRATIONS="true"


# -------------------------------------------------------------------
# 🕐 Scheduler (deshabilitado por defecto en desarrollo)
# -------------------------------------------------------------------
ENABLE_CASH_CLOSURE_SCHEDULER="false"


# -------------------------------------------------------------------
# 👤 Bootstrap — Datos iniciales para desarrollo/demo
# -------------------------------------------------------------------
# ⚠️  Estos son valores de DEMO. No usar en producción.
BOOTSTRAP_OWNER_EMAIL="owner@yourcompany.com"
BOOTSTRAP_OWNER_NAME="Owner Demo"
BOOTSTRAP_OWNER_PASSWORD="DemoPassword!123"

BOOTSTRAP_SYSADMIN_EMAIL="sysadmin@yourcompany.com"
BOOTSTRAP_SYSADMIN_NAME="System Administrator Demo"
BOOTSTRAP_SYSADMIN_PASSWORD="DemoPassword!456"

BOOTSTRAP_BRANCH_CODE="MGA"
BOOTSTRAP_BRANCH_NAME="Sucursal Principal"
BOOTSTRAP_CREATE_CASH_BOX="true"


# -------------------------------------------------------------------
# 🧪 Demo / Staging (NO usar en producción)
# -------------------------------------------------------------------
E2E_BOOTSTRAP_PASSWORD="DemoPassword!123"
TEST_USER_PASSWORD="DemoPassword!123"


# -------------------------------------------------------------------
# 🧪 E2E Tests (opcionales)
# -------------------------------------------------------------------
E2E_BASE_URL="http://127.0.0.1:3000"
E2E_ADMIN_STORAGE_STATE="tests/e2e/.auth/admin.json"
E2E_CASHIER_STORAGE_STATE="tests/e2e/.auth/cashier.json"
E2E_ADMIN_EMAIL="supervisor.mga@hammer.local"
E2E_ADMIN_PASSWORD="DemoPassword!123"
E2E_CASHIER_EMAIL="caja.mga@hammer.local"
E2E_CASHIER_PASSWORD="DemoPassword!123"
