# =============================================================================
# H.A.M.M.E.R. POS — Plantilla de Variables de Entorno para PRODUCCIÓN
# =============================================================================
#
# ⚠️  ADVERTENCIA: Este archivo contiene SOLO ejemplos y placeholders.
#     NUNCA usar estos valores tal como están en un entorno real.
#     NUNCA commitear .env.production al repositorio.
#
# INSTRUCCIONES:
#   1. Copiar:  cp .env.production.example .env.production
#   2. Reemplazar TODOS los valores marcados con "CHANGE_ME" o "REPLACE_"
#   3. Generar secretos seguros (ver comandos abajo)
#   4. Validar:  APP_ENV=production NODE_ENV=production node scripts/validate-env.mjs --mode=strict
#
# USO CON DOCKER COMPOSE:
#   docker compose -f docker-compose.production.yml --env-file .env.production up -d
#
# =============================================================================


# =============================================================================
# 🔒 ENTORNO — Obligatorio
# =============================================================================
# Estas dos variables DEBEN ser "production" en un despliegue real.
# El script validate-env.mjs fallará si no lo son.
APP_ENV="production"
NODE_ENV="production"


# =============================================================================
# 🌐 DOMINIO — Obligatorio para HTTPS (Caddy / Let's Encrypt)
# =============================================================================
# Tu dominio real apuntando al servidor. Caddy genera certificados SSL
# automáticamente via Let's Encrypt.
# Ejemplo: pos.tuempresa.com
DOMAIN="pos.tuempresa.com"


# =============================================================================
# 🐘 BASE DE DATOS — PostgreSQL (Obligatorio)
# =============================================================================
# Formato obligatorio: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# ⚠️  SQLite NO es soportado en producción.
#
# Estas variables configuran el contenedor PostgreSQL Y la conexión de la app.
# ⚠️  CAMBIAR contraseña obligatoriamente antes de desplegar.
#
# 🔑 Generar contraseña segura:
#     openssl rand -base64 32
#
POSTGRES_USER="hammer"
POSTGRES_PASSWORD="CHANGE_ME_USE_openssl_rand_base64_32"
POSTGRES_DB="hammer_pos"

# DATABASE_URL se construye automáticamente en docker-compose.production.yml
# Si NO usas Docker Compose, descomenta y configura manualmente:
# DATABASE_URL="postgresql://hammer:TU_PASSWORD_SEGURO@localhost:5432/hammer_pos?sslmode=require"


# =============================================================================
# 🔐 SEGURIDAD DE SESIÓN — Obligatorio
# =============================================================================
# ⚠️  ADVERTENCIA CRÍTICA: Generar un valor ÚNICO y SEGURO.
#     NO usar el placeholder. NO usar valores cortos o predecibles.
#     Mínimo 32 caracteres aleatorios.
#
# 🔑 Generar secreto seguro (elegir UNO):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#     openssl rand -hex 32
#     python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Si cambias este valor, TODAS las sesiones activas se invalidarán.
#
AUTH_SESSION_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32"

# Duración de la sesión en horas.
# Recomendado: 8 (jornada laboral) o 12 (valor por defecto).
# Valores más bajos = más seguro pero menos conveniente.
AUTH_SESSION_TTL_HOURS="8"


# =============================================================================
# ⚙️  CONFIGURACIÓN DE APLICACIÓN
# =============================================================================
# Puerto interno del contenedor (normalmente no cambiar)
PORT="3000"

# Ejecutar migraciones automáticamente al iniciar el contenedor.
# true  = Las migraciones Prisma se ejecutan en cada inicio (recomendado).
# false = Debes ejecutar migraciones manualmente antes de iniciar.
# Tip: Usar "true" para despliegues simples. Usar "false" si prefieres
#      controlar las migraciones por separado (ej: en un pipeline CI/CD).
RUN_MIGRATIONS="true"

# Scheduler de cierre automático de caja.
# true  = Cierre automático activo (ejecuta al final del día).
# false = Solo cierre manual por parte de los usuarios.
ENABLE_CASH_CLOSURE_SCHEDULER="false"


# =============================================================================
# 👤 BOOTSTRAP — Usuario inicial (solo primer despliegue)
# =============================================================================
# Estos datos se usan con:
#   docker compose -f docker-compose.production.yml exec app npm run seed:production
#
# ⚠️  Después del primer seed exitoso:
#   1. Cambiar las contraseñas desde la interfaz del sistema
#   2. Eliminar estas variables de .env.production
#   3. NUNCA reusar contraseñas de bootstrap en producción
#
# 🔑 Generar contraseñas seguras para bootstrap:
#     openssl rand -base64 16
#

# --- Owner (dueño del sistema) ---
BOOTSTRAP_OWNER_EMAIL="owner@tuempresa.com"
BOOTSTRAP_OWNER_NAME="Propietario"
BOOTSTRAP_OWNER_PASSWORD="CHANGE_ME_OwnerStrongPassword"

# --- System Admin ---
BOOTSTRAP_SYSADMIN_EMAIL="admin@tuempresa.com"
BOOTSTRAP_SYSADMIN_NAME="Administrador del Sistema"
BOOTSTRAP_SYSADMIN_PASSWORD="CHANGE_ME_SysAdminStrongPassword"

# --- Sucursal inicial ---
BOOTSTRAP_BRANCH_CODE="SUC01"
BOOTSTRAP_BRANCH_NAME="Sucursal Principal"
BOOTSTRAP_CREATE_CASH_BOX="true"


# =============================================================================
# 📝 VARIABLES OPCIONALES
# =============================================================================
# Las siguientes variables son opcionales. Descomenta solo si las necesitas.

# --- Logging / Observabilidad ---
# LOG_LEVEL="info"                     # Nivel de log: debug, info, warn, error
# SENTRY_DSN=""                        # DSN de Sentry para rastreo de errores

# --- E-mail / Notificaciones ---
# SMTP_HOST=""                         # Servidor SMTP
# SMTP_PORT="587"                      # Puerto SMTP
# SMTP_USER=""                         # Usuario SMTP
# SMTP_PASSWORD=""                     # Contraseña SMTP
# SMTP_FROM="noreply@tuempresa.com"    # Remitente de correos

# CORS: comma-separated list of allowed origins for cross-origin API requests
# ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000
