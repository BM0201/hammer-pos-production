# H.A.M.M.E.R. Frontend - environment variables
# Configure these in Vercel Project Settings for the hammer-frontend project.

# Backend URL used by next.config.ts rewrites. In production, set this to the
# public hammer-api Vercel URL without a trailing slash.
BACKEND_URL="https://hammer-api.vercel.app"

# Public frontend origin.
NEXT_PUBLIC_SITE_URL="https://hammer-frontend.vercel.app"
