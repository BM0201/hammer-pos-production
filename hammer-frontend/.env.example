# ============================================================================
# H.A.M.M.E.R. Frontend — Environment variables
# ============================================================================
# Copy to `.env.local` (development) or configure in Vercel Project Settings
# (production).

# ---------------------------------------------------------------------------
# Backend URL — used by `next.config.ts` rewrites
# ---------------------------------------------------------------------------
# All `/api/*` requests are rewritten at Vercel's edge to this URL.
# Same-origin from the browser's perspective, so cookies + CSRF headers work.
#
# Production example: https://hammer-api.vercel.app
# Local dev (running backend on port 4000):
BACKEND_URL="http://localhost:4000"

# ---------------------------------------------------------------------------
# Public site URL (optional, used by metadata / canonical links)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
