{
  "name": "hammer-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "type": "module",
  "description": "H.A.M.M.E.R. POS/ERP — Frontend (UI-only) — Next.js 15",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:e2e": "cd ../hammer-api && npm exec -- tsx prisma/e2e-seed.ts && cd ../hammer-frontend && playwright test",
    "test:e2e:ui": "cd ../hammer-api && npm exec -- tsx prisma/e2e-seed.ts && cd ../hammer-frontend && playwright test --ui",
    "lint": "eslint .",
    "security:audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "lucide-react": "1.7.0",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
