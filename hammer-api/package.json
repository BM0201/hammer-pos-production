{
  "name": "hammer-api",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "type": "module",
  "description": "H.A.M.M.E.R. POS/ERP — Backend (API-only) — Next.js 15 + Prisma + Neon PostgreSQL",
  "scripts": {
    "dev": "next dev --port 4000",
    "build": "npm run prisma:generate && next build",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && next build",
    "start": "next start --port 4000",
    "test": "node --import tsx --test src/modules/dashboard/access.test.ts src/modules/rbac/effective-permissions.test.ts src/modules/workflow/branch-workflow.test.ts src/modules/transport/validators.test.ts src/lib/api/errors.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:format": "prisma format",
    "prisma:validate": "node scripts/prisma-validate.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:deploy:standard": "prisma validate && prisma generate && prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed-production.ts",
    "auth:reset-master": "RESET_MASTER_PASSWORD=true tsx prisma/seed.ts",
    "security:audit": "npm audit --omit=dev",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "0.10.4",
    "@prisma/adapter-neon": "6.19.3",
    "@prisma/client": "6.19.3",
    "exceljs": "^4.4.0",
    "next": "15.5.18",
    "prisma": "6.19.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsx": "4.22.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
