# ============================================================================
# H.A.M.M.E.R. API (backend) — Environment variables
# ============================================================================
# Copy to `.env.local` (development) or configure in Vercel Project Settings
# (production). Never commit real secrets.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
NODE_ENV="development"
APP_ENV="development"

# ---------------------------------------------------------------------------
# Database — Neon PostgreSQL (production) or local Postgres (development)
# ---------------------------------------------------------------------------
# DATABASE_URL: pooled connection used by the running app.
#   For Neon, use the "Pooled connection" string with ?pgbouncer=true&connect_timeout=15
#   For local dev, use a direct postgres:// URL.
DATABASE_URL="postgresql://hammer:hammer@localhost:5432/hammer_pos_dev"

# DIRECT_URL: direct (non-pooled) connection used only by `prisma migrate`
# and `prisma db push`. Required when DATABASE_URL points to a pooler.
# In local dev, set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://hammer:hammer@localhost:5432/hammer_pos_dev"

# Enable the Neon serverless driver adapter (true in Vercel/production).
# When false (default), Prisma uses its native PostgreSQL driver — best for
# local development against a plain Postgres instance.
PRISMA_USE_NEON_ADAPTER="false"

# ---------------------------------------------------------------------------
# Session / auth
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET="REPLACE_WITH_RANDOM_HEX_AT_LEAST_32_CHARS"
AUTH_SESSION_TTL_HOURS="12"

# ---------------------------------------------------------------------------
# Cron / scheduled jobs
# ---------------------------------------------------------------------------
# Shared secret used by Vercel Cron to authenticate against /api/cron/*.
# Generate with: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_RANDOM_HEX"

ENABLE_CASH_CLOSURE_SCHEDULER="false"

# ---------------------------------------------------------------------------
# Bootstrap (optional, used by `npm run db:seed`)
# ---------------------------------------------------------------------------
BOOTSTRAP_OWNER_EMAIL="owner@yourcompany.com"
BOOTSTRAP_OWNER_NAME="Owner"
BOOTSTRAP_OWNER_PASSWORD="ChangeMe!123"

BOOTSTRAP_SYSADMIN_EMAIL="sysadmin@yourcompany.com"
BOOTSTRAP_SYSADMIN_NAME="System Administrator"
BOOTSTRAP_SYSADMIN_PASSWORD="ChangeMe!456"

BOOTSTRAP_BRANCH_CODE="MGA"
BOOTSTRAP_BRANCH_NAME="Sucursal Principal"
BOOTSTRAP_CREATE_CASH_BOX="true"
