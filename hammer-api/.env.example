# H.A.M.M.E.R. API - environment variables
# Configure these in Vercel Project Settings for the hammer-api project.

# Runtime
NODE_ENV="production"

# PostgreSQL / Prisma (Neon)
# DATABASE_URL is the pooled Neon connection used by the app at runtime.
# DIRECT_URL is the direct Neon connection used by prisma migrate deploy.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth
# Required in production. Generate at least 32 chars, for example:
# openssl rand -hex 32
AUTH_SESSION_SECRET="replace_with_random_64_hex_chars"
AUTH_SESSION_TTL_HOURS="12"

# Vercel cron endpoint protection for /api/cron/* and /api/system/cron/*.
CRON_SECRET="replace_with_random_cron_secret"

# Neon serverless adapter. Use "true" when deploying to production with Neon.
PRISMA_USE_NEON_ADAPTER="true"

# Cash closure scheduler. Keep "false" on Vercel because Vercel Cron triggers
# /api/system/cron/cash-auto-close.
ENABLE_CASH_CLOSURE_SCHEDULER="false"

# Production seed/bootstrap variables.
# MASTER_INITIAL_USERNAME, MASTER_INITIAL_PASSWORD, and BOOTSTRAP_* are NOT used
# by Vercel build automatically. Use only when running seed manually:
# npm run db:seed:prod
MASTER_INITIAL_USERNAME="master"
MASTER_INITIAL_PASSWORD="replace_with_strong_initial_password"
BOOTSTRAP_BRANCH_CODE="MGA"
BOOTSTRAP_BRANCH_NAME="Managua Central"
BOOTSTRAP_CREATE_CASH_BOX="true"
