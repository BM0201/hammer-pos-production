# ===================================================================
# H.A.M.M.E.R. POS - Entorno de desarrollo LOCAL
# ===================================================================
# Copia este archivo a .env para desarrollo local:
#   cp .env.local.example .env
#
# O ejecuta:  npm run local:prepare-env
# ===================================================================

# -------------------------------------------------------------------
# Base de datos — PostgreSQL REQUERIDO (SQLite NO es soportado)
# -------------------------------------------------------------------
# Opción 1: PostgreSQL local instalado en tu máquina
# DATABASE_URL="postgresql://tu_usuario:tu_password@localhost:5432/hammer_pos_dev"
#
# Opción 2: Docker (recomendado para desarrollo rápido)
#   docker run -d --name hammer-pg \
#     -e POSTGRES_USER=hammer \
#     -e POSTGRES_PASSWORD=hammer \
#     -e POSTGRES_DB=hammer_pos_dev \
#     -p 5432:5432 \
#     postgres:16-alpine
#
DATABASE_URL="postgresql://hammer:hammer@localhost:5432/hammer_pos_dev"

# -------------------------------------------------------------------
# Seguridad de sesión
# -------------------------------------------------------------------
# Se genera automáticamente por `npm run local:prepare-env` si está vacío.
# Generar manualmente: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"
AUTH_SESSION_TTL_HOURS="24"

# -------------------------------------------------------------------
# Configuración de la aplicación
# -------------------------------------------------------------------
NODE_ENV="development"
APP_ENV="local"
PORT="3000"
RUN_MIGRATIONS="true"

# -------------------------------------------------------------------
# Scheduler (deshabilitado por defecto en local)
# -------------------------------------------------------------------
ENABLE_CASH_CLOSURE_SCHEDULER="false"

# -------------------------------------------------------------------
# Bootstrap — datos iniciales para desarrollo
# -------------------------------------------------------------------
BOOTSTRAP_OWNER_EMAIL="owner@hammer.local"
BOOTSTRAP_OWNER_NAME="Owner Dev"
BOOTSTRAP_OWNER_PASSWORD="DevPassword!123"

BOOTSTRAP_SYSADMIN_EMAIL="sysadmin@hammer.local"
BOOTSTRAP_SYSADMIN_NAME="SysAdmin Dev"
BOOTSTRAP_SYSADMIN_PASSWORD="DevPassword!456"

BOOTSTRAP_BRANCH_CODE="DEV"
BOOTSTRAP_BRANCH_NAME="Sucursal Desarrollo"
BOOTSTRAP_CREATE_CASH_BOX="true"

# -------------------------------------------------------------------
# E2E Tests (opcional)
# -------------------------------------------------------------------
E2E_BASE_URL="http://127.0.0.1:3000"
E2E_BOOTSTRAP_PASSWORD="DevPassword!123"
TEST_USER_PASSWORD="DevPassword!123"
